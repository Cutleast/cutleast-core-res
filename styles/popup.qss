/* Tooltips & Toast */
QToolTip,
Toast QFrame#content_frame,
Popup QFrame#content_frame {
    background-color: @popup_bg_color;
    color: @popup_fg_color;
    border: 1px solid @border_color;
    padding: 2px;
    border-radius: 8px;
}

Toast QLabel {
    color: @popup_fg_color;
}
